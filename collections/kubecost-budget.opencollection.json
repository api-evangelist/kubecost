            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new recurring budget rule for Kubernetes spending."
        },
        {
          "info": {
            "name": "Kubecost Get a specific budget",
            "type": "http"
          },
          "http": {
