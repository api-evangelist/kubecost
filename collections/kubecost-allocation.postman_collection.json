        {
          "id": "40d2eb7c-1428-4d65-b49e-5535165ce6a0",
          "name": "Kubecost Query allocation cost data",
          "request": {
            "name": "Kubecost Query allocation cost data",
            "description": {
              "content": "Retrieves cost allocation data for Kubernetes workloads, aggregated by the specified field over the given time window.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "model",
                "allocation"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "window",
                  "value": "<string>",
                  "description": "(Required) Duration of time over which to query. Accepts units of time (e.g. 3d, 24h, 7d), relative time (e.g. yesterday, lastweek, lastmonth), or RFC3339 date pairs."
                },
                {
                  "disabled": false,
                  "key": "aggregate",
                  "value": "<string>",
                  "description": "Field by which to aggregate results. Supported values include cluster, namespace, controllerKind, controller, service, deployment, statefulset, daemonset, job, label, annotation, pod, and container. Supports multi-aggregation via comma-separated values."
                },
                {
                  "disabled": false,
                  "key": "step",
                  "value": "<string>",
                  "description": "Duration of a single allocation set. If unspecified, this defaults to the window, so that you receive exactly one set for the entire window."
                },
                {
                  "disabled": false,
                  "key": "accumulate",
                  "value": "false",
                  "description": "If true, sum the entire range of sets into a single set."
                },
                {
                  "disabled": false,
                  "key": "idle",
                  "value": "true",
                  "description": "Whether to return idle cost. If true, idle allocations are returned."
                },
                {
                  "disabled": false,
                  "key": "external",
                  "value": "false",
                  "description": "Whether to include external (out-of-cluster) costs."
                },
                {
                  "disabled": false,
                  "key": "filterClusters",
                  "value": "<string>",
                  "description": "Filter results by cluster name (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterNamespaces",
                  "value": "<string>",
                  "description": "Filter results by namespace (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterControllerKinds",
                  "value": "<string>",
                  "description": "Filter results by controller kind (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterControllers",
                  "value": "<string>",
                  "description": "Filter results by controller name (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterLabels",
                  "value": "<string>",
                  "description": "Filter results by label in the format label:value (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterAnnotations",
                  "value": "<string>",
                  "description": "Filter results by annotation in the format annotation:value (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterServices",
                  "value": "<string>",
                  "description": "Filter results by service (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "shareIdle",
                  "value": "false",
                  "description": "If true, idle cost is allocated proportionally across tenants."
                },
                {
                  "disabled": false,
                  "key": "splitIdle",
                  "value": "false",
                  "description": "If true, idle cost is split into separate allocations by cluster and node."
                },
                {
                  "disabled": false,
                  "key": "idleByNode",
                  "value": "false",
                  "description": "If true, idle allocations are created on a per-node basis."
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "json",
                  "description": "Output format. Supports csv and json."
                }
              ],
              "variable": [
                {
                  "description": "Address of the Kubecost instance",
                  "type": "any",
                  "value": "{{kubecost-address}}",
                  "key": "kubecost-address"
                }
              ]
            },
            "header": [
