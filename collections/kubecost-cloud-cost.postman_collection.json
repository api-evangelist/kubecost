          "name": "Kubecost Query cloud cost data",
          "request": {
            "name": "Kubecost Query cloud cost data",
            "description": {
              "content": "Retrieves cloud cost data from cloud service providers, with support for aggregation and filtering.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "model",
                "cloudCost"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "window",
                  "value": "<string>",
                  "description": "(Required) Duration of time over which to query. Accepts daily intervals (e.g. 3d) or RFC3339 date pairs."
                },
                {
                  "disabled": false,
                  "key": "aggregate",
                  "value": "<string>",
                  "description": "Field by which to aggregate results. Supported values include invoiceEntityID, accountID, provider, service, and label:<name>. Supports multi-aggregation via comma-separated values."
                },
                {
                  "disabled": false,
                  "key": "accumulate",
                  "value": "false",
                  "description": "If true, sum the entire range into a single set."
                },
                {
                  "disabled": false,
                  "key": "filterInvoiceEntityIDs",
                  "value": "<string>",
                  "description": "Filter by invoice entity ID (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterAccountIDs",
                  "value": "<string>",
                  "description": "Filter by account ID (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterProviders",
                  "value": "<string>",
                  "description": "Filter by provider (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterServices",
                  "value": "<string>",
                  "description": "Filter by service (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterLabels",
                  "value": "<string>",
                  "description": "Filter by label in the format label:value."
                }
              ],
              "variable": [
                {
                  "description": "Address of the Kubecost instance",
                  "type": "any",
                  "value": "{{kubecost-address}}",
                  "key": "kubecost-address"
