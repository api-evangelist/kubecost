                  "description": "(Required) Historical window of time to use as the basis for the forecast."
                },
                {
                  "disabled": false,
                  "key": "forecastWindow",
                  "value": "<string>",
                  "description": "Duration of time to forecast into the future."
                },
                {
                  "disabled": false,
                  "key": "aggregate",
                  "value": "<string>",
                  "description": "Field by which to aggregate results. Supports the same values as the Allocation API aggregate parameter."
                },
                {
                  "disabled": false,
                  "key": "accumulate",
                  "value": "false",
                  "description": "If true, sum the entire range into a single set."
