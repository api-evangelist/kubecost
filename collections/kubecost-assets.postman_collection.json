        {
          "id": "29f2a537-ba77-45b4-8a84-090a9b2177a5",
          "name": "Kubecost Query asset cost data",
          "request": {
            "name": "Kubecost Query asset cost data",
            "description": {
              "content": "Retrieves cost data for individual Kubernetes assets such as nodes, persistent volumes, load balancers, and cluster management costs.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "model",
                "assets"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "window",
                  "value": "<string>",
                  "description": "(Required) Duration of time over which to query. Accepts units of time (e.g. 3d, 24h, 7d), relative time (e.g. yesterday, lastweek), or RFC3339 date pairs."
                },
                {
                  "disabled": false,
                  "key": "aggregate",
                  "value": "<string>",
                  "description": "Field by which to aggregate results. Supported values include account, category, cluster, name, project, providerid, provider, service, type, department, environment, owner, product, team, and label:<name>. Supports multi-aggregation via comma-separated values."
                },
                {
                  "disabled": false,
                  "key": "accumulate",
                  "value": "false",
                  "description": "If true, sum the entire range into a single set."
                },
                {
                  "disabled": false,
                  "key": "filterClusters",
                  "value": "<string>",
                  "description": "Filter by cluster name (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterTypes",
                  "value": "<string>",
                  "description": "Filter by asset type (comma-separated). Supported values include Node, Disk, LoadBalancer, ClusterManagement, Network, Attached."
                },
                {
                  "disabled": false,
                  "key": "filterAccounts",
                  "value": "<string>",
                  "description": "Filter by account (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterProjects",
                  "value": "<string>",
                  "description": "Filter by project (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterProviders",
                  "value": "<string>",
                  "description": "Filter by provider (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterCategories",
                  "value": "<string>",
                  "description": "Filter by category (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "filterLabels",
                  "value": "<string>",
                  "description": "Filter by label in the format label:value."
                },
                {
                  "disabled": false,
                  "key": "filterServices",
                  "value": "<string>",
                  "description": "Filter by service (comma-separated)."
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "json",
                  "description": "Output format. Supports csv and json."
                }
              ],
              "variable": [
                {
                  "description": "Address of the Kubecost instance",
                  "type": "any",
                  "value": "{{kubecost-address}}",
                  "key": "kubecost-address"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
